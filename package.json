{
  "name": "@libra-mcp/libra-test",
  "version": "0.1.3",
  "description": "Zero-config CLI to run static and LLM rules against a codebase — day-one wow moment for Libra",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "libra-test": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.cjs",
    "test": "node --test \"dist/**/*.test.js\" 2>/dev/null || true",
    "prepare": "pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
